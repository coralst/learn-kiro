{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Run ruff linter on the specific Python file that was edited.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "ruff check --fix ${file}"
  }
}
