{
  "enabled": true,
  "name": "Git Status on Prompt",
  "description": "On every prompt submit, check git status and warn if there are too many uncommitted changes or if we're on main.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "echo \"=== Branch ===\" && git branch --show-current && echo \"=== Uncommitted ===\" && git status --short | head -20"
  }
}